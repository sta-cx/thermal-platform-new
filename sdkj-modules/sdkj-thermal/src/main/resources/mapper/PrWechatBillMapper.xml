<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.sdkj.thermal.mapper.PrWechatBillMapper">

    <select id="selectByDateAndType" resultType="org.sdkj.thermal.domain.PrWechatBill">
        SELECT * FROM pr_wechat_bill
        WHERE bill_date = #{billDate} AND bill_type = #{billType} AND del_flag = 0
    </select>

</mapper>
