<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.sdkj.thermal.mapper.AgUserMapper">

    <resultMap id="BaseResultMap" type="org.sdkj.thermal.domain.vo.AgUserVo">
        <id column="id" property="id"/>
        <result column="user_name" property="userName"/>
        <result column="phone" property="phone"/>
        <result column="real_name" property="realName"/>
        <result column="nick_name" property="nickName"/>
        <result column="idcard" property="idcard"/>
        <result column="sex" property="sex"/>
        <result column="email" property="email"/>
        <result column="wx_number" property="wxNumber"/>
        <result column="company_id" property="companyId"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="is_super" property="isSuper"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectUserPage" resultMap="BaseResultMap">
        SELECT id, user_name, phone, real_name, nick_name, idcard, sex, email, wx_number,
               company_id, is_enabled, is_super, create_time
        FROM ag_user
        WHERE company_id = #{companyId}
          AND del_flag = '0'
          AND is_super = '0'
        <if test="name != null and name != ''">
            AND real_name LIKE CONCAT('%', #{name}, '%')
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="checkPhone" resultType="int">
        SELECT COUNT(1) FROM ag_user WHERE phone = #{phone}
    </select>

    <select id="hasUserRole" resultType="int">
        SELECT COUNT(1) FROM ag_user_role WHERE user_id = #{userId}
    </select>

    <delete id="deleteUserRole">
        DELETE FROM ag_user_role WHERE user_id = #{userId}
    </delete>

    <insert id="saveUserRole">
        INSERT INTO ag_user_role (id, user_id, role_id) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (REPLACE(UUID(), '-', ''), #{userId}, #{roleId})
        </foreach>
    </insert>

</mapper>
