<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.sdkj.thermal.mapper.PrWechatUserMapper">

    <select id="selectByOpenId" resultType="org.sdkj.thermal.domain.PrWechatUser">
        SELECT * FROM pr_wechat_user
        WHERE open_id = #{openId} AND del_flag = 0
    </select>

    <select id="selectByOpenIdAndOtherCode" resultType="org.sdkj.thermal.domain.PrWechatUser">
        SELECT * FROM pr_wechat_user
        WHERE open_id = #{openId} AND other_code = #{otherCode} AND del_flag = 0
    </select>

</mapper>
